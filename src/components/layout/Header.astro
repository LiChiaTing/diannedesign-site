---
import en from '../../i18n/en.json';
import zh from '../../i18n/zh-TW.json';

const nav = [
  { href: '/work',     en: en.nav.work,     zh: zh.nav.work     },
  { href: '/about',    en: en.nav.about,    zh: zh.nav.about    },
  { href: '/creative', en: en.nav.creative, zh: zh.nav.creative },
  { href: '/contact',  en: en.nav.contact,  zh: zh.nav.contact  },
];
---

<header class="fixed top-0 left-0 right-0 z-50 px-8 md:px-16 lg:px-24 py-6 flex items-center justify-between" id="site-header">
  <!-- Logo -->
  <a href="/" class="text-sm font-semibold tracking-widest uppercase" data-hover>
    <span class="en-text">Dianne Ting</span>
    <span class="zh-text">丁立佳</span>
  </a>

  <!-- Nav -->
  <nav class="hidden md:flex items-center gap-8">
    {nav.map(item => (
      <a href={item.href} class="text-sm text-gray-DEFAULT hover:text-black transition-colors duration-200" data-hover>
        <span class="en-text">{item.en}</span>
        <span class="zh-text">{item.zh}</span>
      </a>
    ))}
  </nav>

  <!-- Right: lang toggle + mobile menu -->
  <div class="flex items-center gap-4">
    <button
      class="lang-toggle-btn text-xs font-medium border border-gray-border rounded-full px-3 py-1 hover:border-black transition-colors duration-200"
      aria-label="Toggle language"
      data-hover
    >
      <span class="en-text">中</span>
      <span class="zh-text">EN</span>
    </button>

    <!-- Mobile nav toggle -->
    <button class="md:hidden" id="mobile-menu-btn" data-hover aria-label="Menu">
      <svg width="20" height="14" viewBox="0 0 20 14" fill="none">
        <line x1="0" y1="1" x2="20" y2="1" stroke="#111" stroke-width="1.5"/>
        <line x1="0" y1="7" x2="20" y2="7" stroke="#111" stroke-width="1.5"/>
        <line x1="0" y1="13" x2="20" y2="13" stroke="#111" stroke-width="1.5"/>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile menu -->
<div id="mobile-menu" class="fixed inset-0 z-40 bg-white flex flex-col items-center justify-center gap-10 opacity-0 pointer-events-none transition-opacity duration-300">
  {nav.map(item => (
    <a href={item.href} class="text-3xl font-light" data-hover>
      <span class="en-text">{item.en}</span>
      <span class="zh-text">{item.zh}</span>
    </a>
  ))}
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  let open = false;

  btn?.addEventListener('click', () => {
    open = !open;
    if (menu) {
      menu.style.opacity = open ? '1' : '0';
      menu.style.pointerEvents = open ? 'auto' : 'none';
    }
  });

  // Close on link click
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      open = false;
      if (menu) {
        menu.style.opacity = '0';
        menu.style.pointerEvents = 'none';
      }
    });
  });

  // Transparent → solid on scroll
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      header?.classList.add('backdrop-blur-sm', 'bg-white/90', 'border-b', 'border-gray-border');
    } else {
      header?.classList.remove('backdrop-blur-sm', 'bg-white/90', 'border-b', 'border-gray-border');
    }
  });
</script>

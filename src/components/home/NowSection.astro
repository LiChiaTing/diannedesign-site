---
import nowData from '../../data/now.json';
---

<section class="section border-t border-gray-border" id="now">
  <div class="mb-12">
    <span class="text-xs font-medium tracking-widest uppercase text-gray-DEFAULT">
      <span class="en-text">Right Now</span>
      <span class="zh-text">現在進行中</span>
    </span>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">

    <!-- Status widget (fetched client-side from /api/status) -->
    <div class="now-widget reveal" id="status-widget">
      <div class="widget-label">
        <span class="en-text">Status</span>
        <span class="zh-text">狀態</span>
      </div>
      <div class="widget-dot"></div>
      <p class="widget-value" id="status-value">
        <span class="en-text">{nowData.status}</span>
        <span class="zh-text">{nowData.status_zh || nowData.status}</span>
      </p>
      <p class="widget-sub" id="status-sub">
        <span class="en-text">{nowData.project}</span>
        <span class="zh-text">{nowData.project_zh || nowData.project}</span>
      </p>
      <p class="widget-note" id="status-task" style="display:none">
        <span class="en-text" id="status-task-en"></span>
        <span class="zh-text" id="status-task-zh"></span>
      </p>
    </div>

    <!-- Thinking widget (static from now.json, updated Friday via GitHub Action) -->
    <div class="now-widget reveal" style="animation-delay: 0.1s">
      <div class="widget-label">
        <span class="en-text">Thinking about</span>
        <span class="zh-text">最近在想</span>
      </div>
      <p class="widget-value text-sm leading-snug">
        <span class="en-text">{nowData.thinking}</span>
        <span class="zh-text">{nowData.thinking_zh || nowData.thinking}</span>
      </p>
    </div>

    <!-- Music widget (fetched client-side from /api/now-playing) -->
    <div class="now-widget reveal" style="animation-delay: 0.2s">
      <div class="widget-label">
        <span class="en-text">Listening to</span>
        <span class="zh-text">正在聽</span>
      </div>
      <p class="widget-value" id="music-title">{nowData.music?.title}</p>
      <p class="widget-sub" id="music-artist">{nowData.music?.artist}</p>
      <p class="widget-note" id="music-status" style="display:none"></p>
    </div>

    <!-- Weather widget (Seattle — fetched client-side) -->
    <div class="now-widget reveal" style="animation-delay: 0.3s" id="weather-widget">
      <div class="widget-label">
        <span class="en-text">Seattle</span>
        <span class="zh-text">西雅圖</span>
      </div>
      <p class="widget-value" id="weather-temp">–</p>
      <p class="widget-sub" id="weather-desc">–</p>
    </div>

  </div>

  <p class="mt-8 text-xs text-gray-DEFAULT">
    <span class="en-text">Updated {nowData.updated}</span>
    <span class="zh-text">更新於 {nowData.updated}</span>
  </p>
</section>

<style>
  .now-widget {
    @apply border border-gray-border rounded-2xl p-6 flex flex-col gap-2 hover:border-black transition-colors duration-300;
    min-height: 140px;
  }
  .widget-label {
    @apply text-xs font-medium tracking-wider uppercase;
    color: var(--gray);
  }
  .widget-dot {
    @apply w-2 h-2 rounded-full;
    background: var(--accent);
    animation: pulse 2.5s ease-in-out infinite;
  }
  .widget-value {
    @apply text-base font-medium;
    color: var(--black);
  }
  .widget-sub {
    @apply text-sm;
    color: var(--gray);
  }
  .widget-note {
    @apply text-xs italic;
    color: var(--gray);
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }
</style>

<script>
  const lang = () =>
    (document.getElementById('html-root')?.getAttribute('data-lang') || 'en') as 'en' | 'zh';

  // --- Status widget ---
  async function loadStatus() {
    try {
      const res = await fetch('/api/status');
      if (!res.ok) return;
      const data = await res.json();

      const valueEl = document.getElementById('status-value');
      const subEl = document.getElementById('status-sub');
      const taskEl = document.getElementById('status-task');
      const taskEnEl = document.getElementById('status-task-en');
      const taskZhEl = document.getElementById('status-task-zh');

      if (!valueEl || !subEl) return;

      if (data.type === 'event') {
        // Active calendar event — replace all content
        valueEl.innerHTML = `<span class="en-text">${data.value}</span><span class="zh-text">${data.value}</span>`;
        subEl.innerHTML = `<span class="en-text">Calendar event</span><span class="zh-text">行事曆事項</span>`;
        if (taskEl) taskEl.style.display = 'none';
      } else {
        // Project mode
        valueEl.innerHTML = `<span class="en-text">${data.project}</span><span class="zh-text">${data.project_zh || data.project}</span>`;
        subEl.innerHTML = `<span class="en-text">${data.value}</span><span class="zh-text">${data.status_zh || data.value}</span>`;
        if (data.task && taskEl && taskEnEl && taskZhEl) {
          taskEnEl.textContent = data.task;
          taskZhEl.textContent = data.task_zh || data.task;
          taskEl.style.display = '';
        }
      }
    } catch {
      // Fail silently — SSR fallback content remains
    }
  }

  // --- Music widget (Spotify) ---
  async function loadMusic() {
    try {
      const res = await fetch('/api/now-playing');
      if (!res.ok || res.status === 204) return;
      const data = await res.json();
      if (!data.title) return;

      const titleEl = document.getElementById('music-title');
      const artistEl = document.getElementById('music-artist');
      const statusEl = document.getElementById('music-status');

      if (titleEl) titleEl.textContent = data.title;
      if (artistEl) artistEl.textContent = data.artist;
      if (statusEl) {
        statusEl.textContent = data.isPlaying ? '▶ Now playing' : 'Recently played';
        statusEl.style.display = '';
      }
    } catch {
      // Fail silently — SSR fallback content remains
    }
  }

  // --- Weather (Open-Meteo) ---
  async function loadWeather() {
    try {
      const res = await fetch(
        'https://api.open-meteo.com/v1/forecast?latitude=47.6062&longitude=-122.3321&current_weather=true&temperature_unit=celsius'
      );
      const data = await res.json();
      const temp = Math.round(data.current_weather.temperature);
      const code = data.current_weather.weathercode;

      const descriptions: Record<number, [string, string]> = {
        0: ['Clear sky', '晴天'],
        1: ['Mainly clear', '大致晴朗'],
        2: ['Partly cloudy', '局部多雲'],
        3: ['Overcast', '陰天'],
        45: ['Fog', '霧'],
        48: ['Fog', '霧'],
        51: ['Light drizzle', '細雨'],
        61: ['Light rain', '小雨'],
        63: ['Moderate rain', '中雨'],
        71: ['Light snow', '小雪'],
        80: ['Showers', '陣雨'],
        95: ['Thunderstorm', '雷暴'],
      };

      const [descEn, descZh] = descriptions[code] || ['–', '–'];
      const tempEl = document.getElementById('weather-temp');
      const descEl = document.getElementById('weather-desc');

      if (tempEl) tempEl.textContent = `${temp}°C`;
      if (descEl) {
        descEl.textContent = lang() === 'zh' ? descZh : descEn;
      }
    } catch {
      // Fail silently
    }
  }

  loadStatus();
  loadMusic();
  loadWeather();
</script>

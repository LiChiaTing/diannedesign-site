---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { getCollection } from 'astro:content';

const allWork = await getCollection('work');
const sorted = allWork
  .filter(p => !p.data.hidden)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Work — Dianne Ting">
  <Header />
  <main class="pt-32">
    <section class="section">
      <span class="text-xs font-medium tracking-widest uppercase text-gray-DEFAULT block mb-12">
        <span class="en-text">All Work</span>
        <span class="zh-text">所有作品</span>
      </span>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {sorted.map(project => (
          <a href={`/work/${project.slug}`} class="group block border border-gray-border rounded-2xl overflow-hidden hover:border-black transition-all duration-300 reveal" data-hover>
            <div class="aspect-video bg-gray-light overflow-hidden relative">
              {project.data.cover ? (
                <img
                  src={project.data.cover}
                  alt={project.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <span class="text-xs text-gray-DEFAULT tracking-widest uppercase">{project.data.title}</span>
                </div>
              )}
              {project.data.locked && (
                <div class="absolute top-3 right-3 w-7 h-7 rounded-full bg-white bg-opacity-90 flex items-center justify-center" style="border:1px solid rgba(0,0,0,0.1);">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                  </svg>
                </div>
              )}
            </div>
            <div class="p-6">
              <div class="flex flex-wrap gap-2 mb-3">
                {project.data.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
                {project.data.aiBuilt && <span class="tag-accent">AI Built ✦</span>}
              </div>
              <h3 class="text-base font-medium mb-1">{project.data.title}</h3>
              <p class="text-sm text-gray-DEFAULT">{project.data.tagline}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { getCollection } from 'astro:content';

const allWork = await getCollection('work');
const sorted = allWork.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Work — Dianne Ting">
  <Header />
  <main class="pt-32">
    <section class="section">
      <span class="text-xs font-medium tracking-widest uppercase text-gray-DEFAULT block mb-12">
        <span class="en-text">All Work</span>
        <span class="zh-text">所有作品</span>
      </span>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {sorted.map(project => (
          <a href={`/work/${project.slug}`} class="group block border border-gray-border rounded-2xl overflow-hidden hover:border-black transition-all duration-300" data-hover>
            <div class="aspect-video bg-gray-light flex items-center justify-center">
              <span class="text-xs text-gray-DEFAULT tracking-widest">{project.data.title}</span>
            </div>
            <div class="p-6">
              <div class="flex flex-wrap gap-2 mb-3">
                {project.data.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
                {project.data.aiBuilt && <span class="tag-accent">AI Built ✦</span>}
              </div>
              <h3 class="text-base font-medium mb-1">{project.data.title}</h3>
              <p class="text-sm text-gray-DEFAULT">{project.data.tagline}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

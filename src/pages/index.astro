---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import HeroOrbit from '../components/home/HeroOrbit.astro';
import NowSection from '../components/home/NowSection.astro';
import { getCollection } from 'astro:content';
import en from '../i18n/en.json';
import zh from '../i18n/zh-TW.json';

const allWork = await getCollection('work');
const featured = allWork
  .filter(p => !p.data.hidden)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);
---

<BaseLayout
  title="Dianne Ting — Product Designer"
  description="Dianne Ting is a Product Designer based in Seattle, specializing in UX/UI design, AI-driven web development, and startup strategy. Designs in Figma. Builds with Claude."
>
  <Header />

  <main>

    <!-- ─── HERO ─────────────────────────────────────────────────── -->
    <section class="relative min-h-[90svh] md:min-h-screen flex items-center" id="hero">

      <!-- Dot grid background -->
      <div
        aria-hidden="true"
        class="absolute inset-0 pointer-events-none"
        style="background-image: radial-gradient(circle, rgba(0,0,0,0.05) 1px, transparent 1px); background-size: 28px 28px;"
      ></div>

      <!-- Left: text content -->
      <div class="w-full md:w-1/2 px-8 md:px-16 lg:px-24 pt-24 md:pt-32 pb-16 md:pb-20">

        <div class="flex items-center gap-2 mb-8 md:mb-10 reveal">
          <span class="w-1.5 h-1.5 rounded-full bg-accent" style="animation: breathe-dot 2.5s ease-in-out infinite;"></span>
          <span class="text-xs font-medium tracking-widest uppercase" style="color:#999;">
            <span class="en-text">{en.hero.badge}</span>
            <span class="zh-text">{zh.hero.badge}</span>
          </span>
        </div>

        <h1 class="text-5xl md:text-7xl lg:text-8xl font-light leading-none tracking-tight mb-6 md:mb-8 reveal" style="transition-delay:0.1s">
          <span class="en-text">{en.hero.headline_line1}<br/>{en.hero.headline_line2}</span>
          <span class="zh-text">{zh.hero.headline_line1}<br/>{zh.hero.headline_line2}</span>
        </h1>

        <p class="text-base leading-relaxed max-w-xs reveal" style="color:#999; transition-delay:0.2s">
          <span class="en-text">{en.hero.sub}</span>
          <span class="zh-text">{zh.hero.sub}</span>
        </p>

        <div class="flex items-center gap-8 mt-10 md:mt-12 reveal" style="transition-delay:0.3s">
          <a href="/work" class="text-sm font-medium hover:text-accent transition-colors duration-200" style="text-decoration:underline; text-underline-offset:4px;" data-hover>
            <span class="en-text">{en.hero.cta}</span>
            <span class="zh-text">{zh.hero.cta}</span>
          </a>
          <a href="/about" class="text-sm transition-colors duration-200 hover:text-black" style="color:#999;" data-hover>
            <span class="en-text">{en.hero.ctaAbout}</span>
            <span class="zh-text">{zh.hero.ctaAbout}</span>
          </a>
        </div>

        <!-- Workflow strip -->
        <div class="flex items-center gap-2 mt-8 reveal" style="transition-delay:0.4s">
          <span class="text-xs tracking-widest uppercase" style="color:#ccc;">{en.hero.workflowLabel}</span>
          <span style="color:#e0e0e0; font-size:10px;">·</span>
          <span class="text-xs" style="color:#bbb;">Figma</span>
          <span class="text-xs" style="color:#ddd;">›</span>
          <span class="text-xs" style="color:#bbb;">Cursor</span>
          <span class="text-xs" style="color:#ddd;">›</span>
          <span class="text-xs" style="color:#bbb;">Vercel</span>
          <span class="text-xs" style="color:#ddd;">›</span>
          <span class="flex items-center gap-1.5">
            <span class="w-1 h-1 rounded-full bg-accent" style="animation: live-blink 1.2s ease-in-out infinite;"></span>
            <span class="text-xs font-medium" style="color: var(--accent);">
              <span class="en-text">{en.hero.live}</span>
              <span class="zh-text">{zh.hero.live}</span>
            </span>
          </span>
        </div>
      </div>

      <!-- Right: orbital cards (desktop only) -->
      <div class="hidden md:block absolute right-0 top-0 w-1/2 h-full pointer-events-none">
        <div class="w-full h-full flex items-center justify-center">
          <HeroOrbit />
        </div>
      </div>
    </section>

    <!-- ─── DIVIDER ───────────────────────────────────────────────── -->
    <div class="px-8 md:px-16 lg:px-24">
      <div style="height:1px; background:rgba(0,0,0,0.06);"></div>
    </div>

    <!-- ─── NOW ──────────────────────────────────────────────────── -->
    <NowSection />

    <!-- ─── DIVIDER ───────────────────────────────────────────────── -->
    <div class="px-8 md:px-16 lg:px-24">
      <div style="height:1px; background:rgba(0,0,0,0.06);"></div>
    </div>

    <!-- ─── SELECTED WORK ─────────────────────────────────────────── -->
    <section class="px-8 md:px-16 lg:px-24 py-24 md:py-36">

      <div class="flex items-center justify-between mb-14">
        <span class="text-xs font-medium tracking-widest uppercase" style="color:#999;">
          <span class="en-text">{en.work.selectedWork}</span>
          <span class="zh-text">{zh.work.selectedWork}</span>
        </span>
        <a href="/work" class="text-sm hover:text-accent transition-colors reveal" data-hover>
          <span class="en-text">{en.work.viewAll}</span>
          <span class="zh-text">{zh.work.viewAll}</span>
        </a>
      </div>

      <!-- Top border -->
      <div style="height:1px; background:rgba(0,0,0,0.08);"></div>

      {featured.map((project, i) => (
        <a
          href={`/work/${project.slug}`}
          class="home-project-row group reveal"
          style={`transition-delay:${i * 0.06}s`}
          data-hover
        >
          <span class="home-row-num">0{i + 1}</span>

          <div class="home-row-title-block">
            <span class="home-row-title">{project.data.title}</span>
            <span class="home-row-tagline">{project.data.tagline}</span>
          </div>

          <div class="home-row-tags">
            {project.data.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
            {project.data.aiBuilt && <span class="tag-accent">AI Built ✦</span>}
          </div>

          <span class="home-row-arrow">
            {project.data.locked
              ? <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              : '→'
            }
          </span>

          <div class="home-row-divider"></div>
        </a>
      ))}
    </section>

    <!-- ─── DIVIDER ───────────────────────────────────────────────── -->
    <div class="px-8 md:px-16 lg:px-24">
      <div style="height:1px; background:rgba(0,0,0,0.06);"></div>
    </div>

    <!-- ─── CREATIVE STRIP ────────────────────────────────────────── -->
    <section class="px-8 md:px-16 lg:px-24 py-24 md:py-36">

      <div class="flex items-center justify-between mb-14">
        <span class="text-xs font-medium tracking-widest uppercase" style="color:#999;">
          <span class="en-text">{en.creative.title}</span>
          <span class="zh-text">{zh.creative.title}</span>
        </span>
        <a href="/creative" class="text-sm hover:text-accent transition-colors" data-hover>
          <span class="en-text">{en.creative.viewAll}</span>
          <span class="zh-text">{zh.creative.viewAll}</span>
        </a>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        {[
          { src: '/images/creative/seattle-alley-night.jpg', alt: 'Seattle alley at night' },
          { src: '/images/creative/post-alley.jpg',          alt: 'Post Alley' },
          { src: '/images/creative/seattle-windows.jpg',     alt: 'Seattle windows' },
          { src: '/images/creative/street-art.jpg',          alt: 'Street art' },
          { src: '/images/creative/seattle-crosswalk.jpg',   alt: 'Seattle crosswalk' },
        ].map((photo, i) => (
          <a
            href="/creative"
            class={`aspect-square rounded-xl overflow-hidden hover:scale-[1.02] transition-transform duration-300 reveal block${i === 4 ? ' hidden md:block' : ''}`}
            style={`background:#f5f5f5; transition-delay:${i * 0.05}s`}
            data-hover
          >
            <img
              src={photo.src}
              alt={photo.alt}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </a>
        ))}
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  @keyframes breathe-dot {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%       { transform: scale(1.4); opacity: 0.5; }
  }

  @keyframes live-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.1; }
  }

  /* ── Homepage project rows ─────────────────────────────────────── */
  .home-project-row {
    position: relative;
    display: grid;
    grid-template-columns: 2.5rem 1fr auto 2rem;
    align-items: center;
    gap: 1.5rem;
    padding: 1.75rem 0;
    text-decoration: none;
    color: inherit;
  }

  .home-project-row::before {
    content: '';
    position: absolute;
    left: -2rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: #E04F72;
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.25s ease;
  }
  .home-project-row:hover::before { transform: scaleY(1); }
  .home-project-row:hover .home-row-title { color: #E04F72; }
  .home-project-row:hover .home-row-arrow { color: #E04F72; transform: translateX(4px); }

  .home-row-divider {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: rgba(0,0,0,0.08);
  }

  .home-row-num {
    font-size: 0.65rem;
    font-weight: 700;
    color: #ccc;
    letter-spacing: 0.08em;
    flex-shrink: 0;
  }

  .home-row-title-block {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .home-row-title {
    font-size: 1.35rem;
    font-weight: 300;
    letter-spacing: -0.02em;
    color: #111;
    transition: color 0.2s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .home-row-tagline {
    font-size: 0.75rem;
    color: #999;
    letter-spacing: 0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .home-row-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: flex-end;
  }

  .home-row-arrow {
    font-size: 0.9rem;
    color: #ccc;
    flex-shrink: 0;
    transition: color 0.2s ease, transform 0.2s ease;
    display: flex;
    align-items: center;
  }

  @media (max-width: 640px) {
    .home-project-row {
      grid-template-columns: 2rem 1fr 1.5rem;
      gap: 0.75rem;
    }
    .home-row-tags { display: none; }
    .home-row-title { font-size: 1.1rem; }
  }
</style>

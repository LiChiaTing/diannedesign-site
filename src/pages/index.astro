---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import HeroOrbit from '../components/home/HeroOrbit.astro';
import NowSection from '../components/home/NowSection.astro';
import { getCollection } from 'astro:content';

const allWork = await getCollection('work');
const featured = allWork.filter(p => p.data.featured);
---

<BaseLayout title="Dianne Ting — Product Designer">
  <Header />

  <main>

    <!-- ─── HERO ─────────────────────────────────────────────────── -->
    <section class="relative min-h-screen flex items-center" id="hero">

      <!-- Left: text content -->
      <div class="w-full md:w-1/2 px-8 md:px-16 lg:px-24 pt-32 pb-20">

        <div class="flex items-center gap-2 mb-10 reveal">
          <span class="w-1.5 h-1.5 rounded-full bg-accent" style="animation: breathe-dot 2.5s ease-in-out infinite;"></span>
          <span class="text-xs font-medium tracking-widest uppercase" style="color:#999;">
            <span class="en-text">Designs in Figma. Builds with Claude.</span>
            <span class="zh-text">在 Figma 設計。和 Claude 一起建造。</span>
          </span>
        </div>

        <h1 class="text-6xl md:text-7xl lg:text-8xl font-light leading-none tracking-tight mb-8 reveal" style="transition-delay:0.1s">
          <span class="en-text">Product<br/>Designer.</span>
          <span class="zh-text">產品<br/>設計師。</span>
        </h1>

        <p class="text-base leading-relaxed max-w-xs reveal" style="color:#999; transition-delay:0.2s">
          <span class="en-text">Dianne turns complex ideas into clear, intuitive experiences. Based in Seattle. Originally from Taipei.</span>
          <span class="zh-text">把複雜的想法，轉化成清晰、直覺的體驗。在西雅圖，來自台北。</span>
        </p>

        <div class="flex items-center gap-8 mt-12 reveal" style="transition-delay:0.3s">
          <a href="/work" class="text-sm font-medium hover:text-accent transition-colors duration-200" style="text-decoration:underline; text-underline-offset:4px;" data-hover>
            <span class="en-text">See my work →</span>
            <span class="zh-text">看我的作品 →</span>
          </a>
          <a href="/about" class="text-sm transition-colors duration-200 hover:text-black" style="color:#999;" data-hover>
            <span class="en-text">About me</span>
            <span class="zh-text">關於我</span>
          </a>
        </div>
      </div>

      <!-- Right: orbital cards (desktop only) -->
      <div class="hidden md:block absolute right-0 top-0 w-1/2 h-full pointer-events-none">
        <div class="w-full h-full flex items-center justify-center">
          <HeroOrbit />
        </div>
      </div>
    </section>

    <!-- ─── DIVIDER ───────────────────────────────────────────────── -->
    <div class="px-8 md:px-16 lg:px-24">
      <div style="height:1px; background:rgba(0,0,0,0.06);"></div>
    </div>

    <!-- ─── NOW ──────────────────────────────────────────────────── -->
    <NowSection />

    <!-- ─── DIVIDER ───────────────────────────────────────────────── -->
    <div class="px-8 md:px-16 lg:px-24">
      <div style="height:1px; background:rgba(0,0,0,0.06);"></div>
    </div>

    <!-- ─── SELECTED WORK ─────────────────────────────────────────── -->
    <section class="px-8 md:px-16 lg:px-24 py-24 md:py-36">

      <div class="flex items-center justify-between mb-14">
        <span class="text-xs font-medium tracking-widest uppercase" style="color:#999;">
          <span class="en-text">Selected Work</span>
          <span class="zh-text">精選作品</span>
        </span>
        <a href="/work" class="text-sm hover:text-accent transition-colors reveal" data-hover>
          <span class="en-text">View all →</span>
          <span class="zh-text">全部作品 →</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {featured.map((project, i) => (
          <a
            href={`/work/${project.slug}`}
            class="group block rounded-2xl overflow-hidden hover:-translate-y-1 transition-all duration-300 reveal"
            style={`border:1px solid rgba(0,0,0,0.08); transition-delay:${i * 0.08}s`}
            data-hover
          >
            <div class="aspect-video overflow-hidden" style="background:#f5f5f5;">
              {project.data.cover ? (
                <img
                  src={project.data.cover}
                  alt={project.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <span class="text-xs tracking-widest uppercase" style="color:#ccc;">{project.data.title}</span>
                </div>
              )}
            </div>
            <div class="p-6">
              <div class="flex flex-wrap gap-2 mb-3">
                {project.data.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
                {project.data.aiBuilt && <span class="tag-accent">AI Built ✦</span>}
              </div>
              <h3 class="text-sm font-semibold mb-1">{project.data.title}</h3>
              <p class="text-sm" style="color:#999;">{project.data.tagline}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ─── DIVIDER ───────────────────────────────────────────────── -->
    <div class="px-8 md:px-16 lg:px-24">
      <div style="height:1px; background:rgba(0,0,0,0.06);"></div>
    </div>

    <!-- ─── CREATIVE STRIP ────────────────────────────────────────── -->
    <section class="px-8 md:px-16 lg:px-24 py-24 md:py-36">

      <div class="flex items-center justify-between mb-14">
        <span class="text-xs font-medium tracking-widest uppercase" style="color:#999;">
          <span class="en-text">Creative</span>
          <span class="zh-text">創作</span>
        </span>
        <a href="/creative" class="text-sm hover:text-accent transition-colors" data-hover>
          <span class="en-text">View all →</span>
          <span class="zh-text">全部 →</span>
        </a>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[1,2,3,4].map(i => (
          <div
            class="aspect-square rounded-xl overflow-hidden hover:scale-[1.02] transition-transform duration-300 reveal"
            style={`background:#f5f5f5; transition-delay:${i * 0.05}s`}
          >
            <div class="w-full h-full flex items-center justify-center">
              <span class="text-xs tracking-widest uppercase" style="color:#ccc;">PHOTO</span>
            </div>
          </div>
        ))}
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  @keyframes breathe-dot {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%       { transform: scale(1.4); opacity: 0.5; }
  }
</style>

---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---
<BaseLayout title="Creative — Dianne Ting">
  <Header />
  <main class="pt-32">
    <section class="section">
      <span class="text-xs font-medium tracking-widest uppercase text-gray-DEFAULT block mb-4">
        <span class="en-text">Creative</span>
        <span class="zh-text">創作</span>
      </span>
      <h1 class="text-4xl font-light mb-12">
        <span class="en-text">Photography & Art</span>
        <span class="zh-text">攝影與藝術</span>
      </h1>
      <p class="text-gray-DEFAULT">
        <span class="en-text">Coming soon — photos and creative work will be added here.</span>
        <span class="zh-text">即將推出——攝影與創作作品將陸續加入。</span>
      </p>
    </section>
  </main>
  <Footer />
</BaseLayout>
